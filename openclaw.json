{
  "acp": {
    "enabled": true,
    "backend": "acpx",
    "defaultAgent": "claude",
    "allowedAgents": [
      "claude",
      "claude-code",
      "claudecode",
      "codex",
      "pi",
      "opencode",
      "gemini",
      "kimi"
    ]
  },
  "models": {
    "providers": {
      "asi1": {
        "baseUrl": "https://api.asi1.ai/v1",
        "apiKey": "${ASI1_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "asi1-mini",
            "name": "ASI1 Mini",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "asi1/asi1-mini"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:18789",
        "http://127.0.0.1:18790"
      ]
    }
  },
  "plugins": {
    "entries": {
      "acpx": {
        "enabled": true,
        "config": {
          "permissionMode": "approve-all"
        }
      }
    }
  }
}
